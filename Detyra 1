        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.image as mpimg\n",
        "\n",
        "plt.rcParams[\"font.family\"] = \"DejaVu Serif\"\n",
        "\n",
        "t = np.linspace(0, 10, 1000)\n",
        "x = np.sin(t) + 0.7*np.sin(2*t) + 0.4*np.cos(4*t)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10,6))\n",
        "\n",
        "img = mpimg.imread(\"background.jpg\")\n",
        "\n",
        "ax.set_xlim(0, 10)\n",
        "ax.set_ylim(min(x)-0.2, max(x)+0.2)\n",
        "\n",
        "ax.imshow(\n",
        "    img,\n",
        "    extent=[0, 10, min(x)-0.2, max(x)+0.2],\n",
        "    aspect=\"auto\",\n",
        "    alpha=0.8,\n",
        "    zorder=0\n",
        ")\n",
        "\n",
        "glow_color = \"#0041c2\"\n",
        "for lw, alpha in [(12,0.05),(10,0.08),(8,0.12),(6,0.18)]:\n",
        "    ax.plot(t, x, color=glow_color, linewidth=lw, alpha=alpha, zorder=1)\n",
        "\n",
        "ax.plot(\n",
        "    t, x,\n",
        "    color=glow_color,\n",
        "    linewidth=2.5,\n",
        "    marker=\"o\",\n",
        "    markersize=5,\n",
        "    markevery=70,\n",
        "    label=\"f(t) = sin(t) + 0.7sin(2t) + 0.4cos(4t)\",\n",
        "    zorder=2\n",
        ")\n",
        "\n",
        "ax.set_title(\"Group Signature Plot\", fontsize=18, color=\"black\")\n",
        "ax.set_xlabel(\"t\", fontsize=14, color=\"black\")\n",
        "ax.set_ylabel(\"f(t)\", fontsize=14, color=\"black\")\n",
        "\n",
        "ax.tick_params(axis='both', colors='black')\n",
        "\n",
        "for spine in ax.spines.values():\n",
        "    spine.set_color(\"black\")\n",
        "\n",
        "ax.grid(True, linestyle=\"--\", linewidth=0.7, alpha=0.5, color=\"black\")\n",
        "\n",
        "ax.legend(facecolor=\"#222222\", edgecolor=\"black\", labelcolor=\"white\")\n",
        "\n",
        "plt.savefig(\"signature_plot.png\", dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n"
