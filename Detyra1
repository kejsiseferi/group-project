        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib as mpl\n",
        "\n",
        "# 1. FONTI DHE MADHËSIA\n",
        "mpl.rcParams['font.family'] = 'DejaVu Serif'\n",
        "mpl.rcParams['font.size'] = 13\n",
        "\n",
        "# 2. TË DHËNAT\n",
        "t = np.linspace(0, 10, 1000)\n",
        "x1 = np.sin(t)\n",
        "x2 = np.sin(t) + np.cos(2*t)\n",
        "\n",
        "# 3. FIGURA\n",
        "fig, ax = plt.subplots(figsize=(10, 5))\n",
        "\n",
        "# 4. IMAZHI I SFONDIT (opsional - nëse nuk ke jumbo.jpg, kalohet)\n",
        "try:\n",
        "    import matplotlib.image as mpimg\n",
        "    img = mpimg.imread('jumbo.jpg')\n",
        "    ax.imshow(img, extent=[0, 10, -2.5, 2.5], aspect='auto', alpha=0.45, zorder=0)\n",
        "except FileNotFoundError:\n",
        "    pass  # nëse nuk ekziston skedari, vazhdon pa sfond\n",
        "\n",
        "# 5. VIZATIMI I VIJAVE\n",
        "ax.plot(t, x1, color='#FF0000', linewidth=6, alpha=0.2, zorder=2)\n",
        "ax.plot(t, x1,\n",
        "        color='#FF3366',\n",
        "        linewidth=2.5,\n",
        "        marker='o',\n",
        "        markevery=80,\n",
        "        markersize=6,\n",
        "        label=r'$x_1 = \\sin(t)$',      # ← KORRIGJUAR: label me tekst\n",
        "        zorder=3)\n",
        "\n",
        "ax.plot(t, x2, color='#006994', linewidth=6, alpha=0.2, zorder=2)\n",
        "ax.plot(t, x2,\n",
        "        color='#006994',\n",
        "        linewidth=2.5,\n",
        "        marker='s',\n",
        "        markevery=80,\n",
        "        markersize=6,\n",
        "        label=r'$x_2 = \\sin(t) + \\cos(2t)$',  # ← KORRIGJUAR: label me tekst\n",
        "        zorder=3)\n",
        "\n",
        "# 6. STILI I RRJETËS\n",
        "ax.grid(True, linestyle=':', linewidth=0.8, color='gray', alpha=0.6)\n",
        "\n",
        "# 7. NGJYRAT E SFONDIT\n",
        "ax.set_facecolor('#F8F9FA')\n",
        "fig.patch.set_facecolor('#FFFFFF')\n",
        "\n",
        "# 8. ETIKETAT DHE TITULLI\n",
        "ax.set_xlabel('t', fontsize=15, fontweight='bold', color='#1D3557')\n",
        "ax.set_ylabel('x(t)', fontsize=15, fontweight='bold', color='#1D3557')\n",
        "ax.set_title('Group Signature Plot', fontsize=18, fontweight='bold',\n",
        "             color='#1D3557', pad=15)\n",
        "\n",
        "# 9. LEGJENDA\n",
        "ax.legend(fontsize=12, loc='upper right', framealpha=0.9, edgecolor='#1D3557')\n",
        "\n",
        "# 10. RUAJTJA (← KORRIGJUAR: savefig PARA show)\n",
        "plt.tight_layout()\n",
        "plt.savefig('signature_plot.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()"
      ]
